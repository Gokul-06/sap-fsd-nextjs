# ─── Database (local Docker PostgreSQL) ───────────────────────────────────────
# Prisma connection pooling URL (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sap_fsd?schema=public"
# Direct connection URL (used by Prisma Migrate)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/sap_fsd?schema=public"

# ─── AI Provider Configuration ────────────────────────────────────────────────
# Provider: anthropic | azure-anthropic | azure-openai | openai
# Default: "anthropic" (if not set, falls back to ANTHROPIC_API_KEY)
AI_PROVIDER="anthropic"

# Model override (optional — uses provider default if empty)
# Anthropic/Azure AI Foundry default: claude-sonnet-4-20250514
# OpenAI/Azure OpenAI default: gpt-4o
AI_MODEL=""

# ─── Anthropic (Direct) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-REPLACE_WITH_YOUR_KEY"

# ─── Azure AI Foundry (Claude models via Azure) ──────────────────────────────
# Set AI_PROVIDER="azure-anthropic" to use this
AZURE_AI_FOUNDRY_ENDPOINT="https://your-resource.services.ai.azure.com"
AZURE_AI_FOUNDRY_API_KEY=""

# ─── Azure OpenAI ────────────────────────────────────────────────────────────
# Set AI_PROVIDER="azure-openai" to use this
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"

# ─── OpenAI (Direct) ─────────────────────────────────────────────────────────
# Set AI_PROVIDER="openai" to use this
OPENAI_API_KEY="sk-REPLACE_WITH_YOUR_KEY"

# ─── CALM Integration ─────────────────────────────────────────────────────────
CALM_API_BASE_URL="https://your-calm-instance.example.com/api"
CALM_TOKEN_URL="https://your-calm-instance.example.com/oauth/token"
CALM_CLIENT_ID="REPLACE_WITH_CLIENT_ID"
CALM_CLIENT_SECRET="REPLACE_WITH_CLIENT_SECRET"
# Set to "true" to use mock data without a real CALM connection
CALM_DEMO_MODE="true"
